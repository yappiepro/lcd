{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint --ext .ts,.vue --fix .",
    "lint:check": "eslint --ext .ts,.vue .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
